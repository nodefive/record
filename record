import json
from threading import Event, Lock, Thread

# ────────────────────────────────────────────────
#              GLOBAL CONFIGURATION
# ────────────────────────────────────────────────
CHUNK = 1024
FORMAT = pyaudio.paInt16

QUALITY_PRESETS = {
    "high":   {"rate": 48000, "channels": 2, "name": "High (48 kHz stereo)"},
    "medium": {"rate": 44100, "channels": 2, "name": "Medium (44.1 kHz stereo)"},
    "low":    {"rate": 44100, "channels": 1, "name": "Low (44.1 kHz mono)"}
}

CONFIG_DIR = os.path.expanduser("~/.config")
SETTINGS_FILE = os.path.join(CONFIG_DIR, "terminal_recorder.json")

# These are set dynamically during load_settings() or first_run_setup()
CURRENT_QUALITY = "high"
RAW_SAVE_DIR = "~/Music/Recordings"
RECORDINGS_DIR = ""
TRASH_DIR = ""

sort_key = "date"
sort_reverse = True

columns = shutil.get_terminal_size().columns

# Audio Threading Globals
stop_event = Event()
pause_event = Event()
playback_event = Event()
frames = []
p = None
stream = None
recording_start_time = 0
paused_duration = 0
last_pause_time = 0
frames_lock = Lock()
preview_p = None
preview_stream = None
is_playing_preview = False
playback_paused = False
is_discarding = False
save_requested = False


# ────────────────────────────────────────────────
#              SETUP & FILE MANAGEMENT
# ────────────────────────────────────────────────

def clear():
    os.system('cls' if os.name == 'nt' else 'clear')


def colored(text, color):
    colors = {
        "red": "\033[91m", "green": "\033[92m", "yellow": "\033[93m",
        "blue": "\033[94m", "cyan": "\033[96m", "magenta": "\033[95m",
        "reset": "\033[0m"
    }
    return f"{colors.get(color, '')}{text}{colors['reset']}"


def print_header(title):
    clear()
    print(title.center(columns))
    print(colored("═" * columns, "blue") + "\n")


def save_settings():
    try:
        os.makedirs(CONFIG_DIR, exist_ok=True)
        config_data = {
            "quality": CURRENT_QUALITY,
            "save_dir": RAW_SAVE_DIR
        }
        with open(SETTINGS_FILE, "w", encoding="utf-8") as f:
            json.dump(config_data, f, indent=4)
    except OSError as e:
        print(colored(f"[ERROR] Could not save settings: {e}", "red"))


def first_run_setup():
    global CURRENT_QUALITY, RAW_SAVE_DIR
    
    print_header("INITIAL SETUP WIZARD")
    print("Welcome to the Terminal Voice Recorder.")
    print("Let's configure your basic settings.\n")

    # 1. Quality Setup
    print(colored("1. Default Recording Quality", "cyan"))
    print("   [1] High   (48 kHz stereo)")
    print("   [2] Medium (44.1 kHz stereo)")
    print("   [3] Low    (44.1 kHz mono)")
    
    q_choice = input("\n   Select (1-3) [Default: 1]: ").strip()
    if q_choice == '2':
        CURRENT_QUALITY = "medium"
    elif q_choice == '3':
        CURRENT_QUALITY = "low"
    else:
        CURRENT_QUALITY = "high"

    # 2. Directory Setup
    print("\n" + colored("2. Storage Location", "cyan"))
    default_dir = "~/Music/Recordings"
    print("   Where would you like to save your audio files?")
    
    dir_choice = input(f"   Enter path [Default: {default_dir}]: ").strip()
    if not dir_choice:
        RAW_SAVE_DIR = default_dir
    else:
        RAW_SAVE_DIR = dir_choice

    save_settings()
    print(colored("\n[SUCCESS] Configuration saved!", "green"))
    time.sleep(1.5)


def load_settings():
    global CURRENT_QUALITY, RAW_SAVE_DIR, RECORDINGS_DIR, TRASH_DIR
    
    if not os.path.exists(SETTINGS_FILE):
        first_run_setup()
    else:
        try:
            with open(SETTINGS_FILE, encoding="utf-8") as f:
                data = json.load(f)
                CURRENT_QUALITY = data.get("quality", "high")
                RAW_SAVE_DIR = data.get("save_dir", "~/Music/Recordings")
        except (json.JSONDecodeError, OSError, TypeError):
            print(colored("[!] Corrupted settings file. Using defaults.", "yellow"))
            time.sleep(1.5)

    if CURRENT_QUALITY not in QUALITY_PRESETS:
        CURRENT_QUALITY = "high"

    # Initialize Directories
    RECORDINGS_DIR = os.path.expanduser(RAW_SAVE_DIR)
    TRASH_DIR = os.path.join(RECORDINGS_DIR, ".trash")
    
    try:
        os.makedirs(RECORDINGS_DIR, exist_ok=True)
        os.makedirs(TRASH_DIR, exist_ok=True)
    except OSError as e:
        print(colored(f"\n[ERROR] Could not create storage directories: {e}", "red"))
        print("Please check your path permissions and try again.")
        sys.exit(1)


def get_rate():
    return QUALITY_PRESETS[CURRENT_QUALITY]["rate"]

def get_channels():
    return QUALITY_PRESETS[CURRENT_QUALITY]["channels"]

def get_quality_name():
    return QUALITY_PRESETS[CURRENT_QUALITY]["name"]


# ────────────────────────────────────────────────
#              AUDIO CORE FUNCTIONS
# ────────────────────────────────────────────────

def callback(in_data, frame_count, time_info, status):
    if stop_event.is_set():
        return (None, pyaudio.paComplete)

    if pause_event.is_set():
        silence = b'\x00' * (frame_count * get_channels() * 2)
        return (silence, pyaudio.paContinue)

    with frames_lock:
        frames.append(in_data)
    return (None, pyaudio.paContinue)


def start_recording():
    global p, stream, frames, recording_start_time, paused_duration, is_discarding, save_requested
    frames = []
    stop_event.clear()
    pause_event.clear()
    playback_event.clear()
    recording_start_time = time.time()
    paused_duration = 0
    is_discarding = False
    save_requested = False

    p = pyaudio.PyAudio()
    stream = p.open(
        format=FORMAT,
        channels=get_channels(),
        rate=get_rate(),
        input=True,
        frames_per_buffer=CHUNK,
        stream_callback=callback
    )
    stream.start_stream()


def pause_recording():
    global last_pause_time
    pause_event.set()
    last_pause_time = time.time()


def resume_recording():
    global paused_duration, last_pause_time
    if last_pause_time > 0:
        paused_duration += time.time() - last_pause_time
        last_pause_time = 0
    pause_event.clear()


def save_current_recording_to_temp():
    with frames_lock:
        if not frames:
            return None

        temp_file = tempfile.NamedTemporaryFile(suffix='.wav', delete=False)
        wf = wave.open(temp_file.name, 'wb')
        wf.setnchannels(get_channels())
        wf.setsampwidth(p.get_sample_size(FORMAT))
        wf.setframerate(get_rate())
        wf.writeframes(b''.join(frames))
        wf.close()
        return temp_file.name


def play_preview():
    global is_playing_preview, playback_paused, preview_p, preview_stream

    temp_file = save_current_recording_to_temp()
    if not temp_file:
        return

    is_playing_preview = True
    playback_paused = False
    playback_event.clear()

    try:
        preview_p = pyaudio.PyAudio()
        with wave.open(temp_file, 'rb') as wf:
            def callback_playback(in_data, frame_count, time_info, status):
                if playback_event.is_set():
                    return (None, pyaudio.paComplete)
                data = wf.readframes(frame_count)
                return (data, pyaudio.paContinue)

            preview_stream = preview_p.open(
                format=preview_p.get_format_from_width(wf.getsampwidth()),
                channels=wf.getnchannels(),
                rate=wf.getframerate(),
                output=True,
                stream_callback=callback_playback
            )

            preview_stream.start_stream()

            while preview_stream.is_active() and not playback_event.is_set():
                time.sleep(0.1)

    except Exception as e:
        pass
    finally:
        if preview_stream:
            preview_stream.stop_stream()
            preview_stream.close()
        if preview_p:
            preview_p.terminate()
        if os.path.exists(temp_file):
            os.unlink(temp_file)
        is_playing_preview = False


def stop_preview():
    global is_playing_preview
    playback_event.set()
    is_playing_preview = False


def pause_preview():
    global playback_paused, preview_stream
    if preview_stream and preview_stream.is_active():
        preview_stream.stop_stream()
        playback_paused = True


def resume_preview():
    global playback_paused, preview_stream
    if preview_stream and playback_paused:
        preview_stream.start_stream()
        playback_paused = False


def discard_recording():
    global stream, p, frames, is_discarding
    stop_event.set()
    stop_preview()
    time.sleep(0.3)

    if stream:
        stream.stop_stream()
        stream.close()
    if p:
        p.terminate()

    with frames_lock:
        frames.clear()

    is_discarding = True
    print(colored("\n[INFO] Recording discarded.", "yellow"))
    time.sleep(1.2)


def get_elapsed_time(start_time):
    if pause_event.is_set() and not is_playing_preview:
        current_pause_duration = time.time() - last_pause_time
        elapsed_secs = int((time.time() - start_time) - paused_duration - current_pause_duration)
    else:
        elapsed_secs = int((time.time() - start_time) - paused_duration)
    return str(timedelta(seconds=elapsed_secs))


def stop_recording_and_save(custom_name_ask=False):
    global stream, p, paused_duration, last_pause_time, save_requested
    stop_event.set()
    stop_preview()

    if last_pause_time > 0:
        paused_duration += time.time() - last_pause_time

    time.sleep(0.4)

    if stream:
        stream.stop_stream()
        stream.close()
    if p:
        p.terminate()

    timestamp = time.strftime("%Y-%m-%d_%H-%M-%S")
    default_name = f"recording_{timestamp}.wav"

    if custom_name_ask:
        clear()
        print(colored("SAVE RECORDING", "cyan").center(columns))
        print(colored("─" * columns, "blue") + "\n")
        print(f"Default name: {default_name}\n")
        custom = input("Enter custom name (or press Enter for default): ").strip()

        if custom:
            custom = "".join(c for c in custom if c.isalnum() or c in " -_()[]")
            custom = custom.strip()
            if not custom.lower().endswith('.wav'):
                custom += '.wav'
            filename = os.path.join(RECORDINGS_DIR, custom)
        else:
            filename = os.path.join(RECORDINGS_DIR, default_name)
    else:
        filename = os.path.join(RECORDINGS_DIR, default_name)

    try:
        wf = wave.open(filename, 'wb')
        wf.setnchannels(get_channels())
        wf.setsampwidth(p.get_sample_size(FORMAT))
        wf.setframerate(get_rate())

        with frames_lock:
            wf.writeframes(b''.join(frames))
        wf.close()

        print("\n" + colored("[SUCCESS] File saved successfully:", "green"))
        print(f"  -> {filename}")

    except Exception as e:
        print(colored(f"[ERROR] Could not save file: {e}", "red"))


def get_current_state():
    if is_playing_preview:
        if playback_paused: return "preview_paused"
        return "preview_playing"
    elif pause_event.is_set():
        return "recording_paused"
    else:
        return "recording"


# ────────────────────────────────────────────────
#              UI MENUS & VIEWS
# ────────────────────────────────────────────────

def record():
    global save_requested
    print_header(f"ACTIVE SESSION: {get_quality_name()}")

    start_time = time.time()
    start_recording()

    try:
        print(colored("[REC] Recording active...", "red"))
        print("Time: 0:00:00")
        print("\nInitializing...")

        display_lines = 4

        while True:
            key = None
            if sys.platform == 'win32':
                import msvcrt
                if msvcrt.kbhit():
                    key = msvcrt.getch().decode('utf-8', errors='ignore').lower()
            else:
                import select
                if select.select([sys.stdin], [], [], 0)[0]:
                    key = sys.stdin.read(1).lower()

            if key:
                handle_keypress(key, start_time)

            update_display(start_time, display_lines)
            time.sleep(0.1)

    except KeyboardInterrupt:
        global is_discarding
        print(colored("\n\n[INFO] Halting process...", "yellow"))

        if not is_discarding and not save_requested:
            stop_recording_and_save(custom_name_ask=False)
        elif is_discarding:
            print(colored("Recording discarded. No file saved.", "yellow"))

        input("\nPress Enter to return to main menu...")


def handle_keypress(key, start_time):
    global last_pause_time, paused_duration, save_requested
    state = get_current_state()

    if key == 'p':
        if state in ("preview_playing", "preview_paused"):
            print(colored("\n[!] Stop preview first (press S)", "red"))
            time.sleep(1)
            return

        if state == "recording_paused":
            resume_recording()
        else:
            pause_recording()
            last_pause_time = time.time()

    elif key == 'l':
        if state != "recording_paused":
            print(colored("\n[!] Pause recording first (press P)", "red"))
            time.sleep(1)
            return

        if state in ("preview_playing", "preview_paused"):
            print(colored("\n[INFO] Preview already active", "yellow"))
            time.sleep(1)
            return

        preview_thread = Thread(target=play_preview, daemon=True)
        preview_thread.start()
        time.sleep(0.1)

    elif key == 's':
        if is_playing_preview:
            stop_preview()
            print(colored("\n[INFO] Preview stopped.", "yellow"))
            time.sleep(0.8)
        else:
            save_requested = True
            stop_recording_and_save(custom_name_ask=True)
            raise KeyboardInterrupt

    elif key == 'd':
        if is_playing_preview:
            print(colored("\n[!] Stop preview first (press S)", "red"))
            time.sleep(1.2)
            return

        print(colored("\nWARNING: Discard this recording? (y/N): ", "red"), end="")
        confirm = input().strip().lower()
        if confirm in ('y', 'yes'):
            discard_recording()
            raise KeyboardInterrupt
        else:
            print(colored("Action cancelled.", "green"))
            time.sleep(0.8)

    elif key == ' ':
        if state == "preview_playing":
            pause_preview()
        elif state == "preview_paused":
            resume_preview()


def update_display(start_time, display_lines):
    elapsed_str = get_elapsed_time(start_time)
    state = get_current_state()

    sys.stdout.write(f"\033[{display_lines}A")
    sys.stdout.write("\033[2K")

    if state == "recording":
        print(colored("[REC] Recording...", "red"))
        controls = "  [P] Pause  [L] Listen  [S] Save  [D] Discard  [Ctrl+C] Save & Exit"
    elif state == "recording_paused":
        print(colored("[PAUSED] Recording Paused", "yellow"))
        controls = "  [P] Resume  [L] Listen  [S] Save  [D] Discard  [Ctrl+C] Save & Exit"
    elif state == "preview_playing":
        print(colored("[PLAY] Listening to Preview", "cyan"))
        controls = "  [Space] Pause  [S] Stop Preview  [Ctrl+C] Save & Exit"
    elif state == "preview_paused":
        print(colored("[PAUSED] Preview Paused", "yellow"))
        controls = "  [Space] Resume  [S] Stop Preview  [Ctrl+C] Save & Exit"

    sys.stdout.write("\033[2K")
    print(f"Elapsed Time: {elapsed_str}")

    sys.stdout.write("\033[2K")
    print()

    sys.stdout.write("\033[2K")
    print(colored(controls, "cyan"))

    sys.stdout.flush()


def format_duration(seconds):
    hours = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    secs = int(seconds % 60)
    if hours > 0:
        return f"{hours}:{minutes:02d}:{secs:02d}"
    return f"{minutes}:{secs:02d}"


def get_file_duration(file_path):
    try:
        with wave.open(file_path, 'rb') as wf:
            frames = wf.getnframes()
            rate = wf.getframerate()
            return frames / float(rate)
    except:
        return 0


def play_recording(filepath):
    print_header("PLAYBACK")
    print(f"File: {colored(os.path.basename(filepath), 'cyan')}")
    dur = get_file_duration(filepath)
    if dur > 0:
        print(f"Duration: {format_duration(dur)}")

    print("\n" + colored("Controls: [Space] Pause/Resume  [S] Stop", "cyan"))
    print(colored("─" * columns, "blue") + "\n")

    try:
        playback_p = pyaudio.PyAudio()
        with wave.open(filepath, 'rb') as wf:
            def cb(in_data, frame_count, time_info, status):
                if playback_event.is_set():
                    return (None, pyaudio.paComplete)
                data = wf.readframes(frame_count)
                return (data, pyaudio.paContinue if data else pyaudio.paComplete)

            stream = playback_p.open(
                format=playback_p.get_format_from_width(wf.getsampwidth()),
                channels=wf.getnchannels(),
                rate=wf.getframerate(),
                output=True,
                stream_callback=cb
            )
            stream.start_stream()

            while stream.is_active() and not playback_event.is_set():
                if sys.platform == 'win32':
                    import msvcrt
                    if msvcrt.kbhit():
                        k = msvcrt.getch().decode('utf-8', errors='ignore').lower()
                        if k == ' ':
                            if stream.is_active(): stream.stop_stream()
                            else: stream.start_stream()
                        else:
                            playback_event.set()
                            break
                else:
                    import select
                    if select.select([sys.stdin], [], [], 0)[0]:
                        k = sys.stdin.read(1).lower()
                        if k == ' ':
                            if stream.is_active(): stream.stop_stream()
                            else: stream.start_stream()
                        else:
                            playback_event.set()
                            break
                time.sleep(0.1)

        stream.stop_stream()
        stream.close()
        playback_p.terminate()
        playback_event.clear()

    except Exception as e:
        print(colored(f"[ERROR] Playback failed: {e}", "red"))

    print(colored("\n[INFO] Playback finished.", "yellow"))
    time.sleep(1)


def list_of_recordings():
    global sort_key, sort_reverse

    while True:
        print_header("SAVED RECORDINGS")
        files = [f for f in os.listdir(RECORDINGS_DIR) if f.lower().endswith(".wav")]

        if not files:
            print(colored("Directory is empty.", "yellow"))
            input("\nPress Enter to return...")
            return

        sort_func = lambda f: 0
        if sort_key == "date":
            sort_func = lambda f: os.path.getmtime(os.path.join(RECORDINGS_DIR, f))
        elif sort_key == "name":
            sort_func = lambda f: f.lower()
        elif sort_key == "duration":
            sort_func = lambda f: get_file_duration(os.path.join(RECORDINGS_DIR, f))

        files = sorted(files, key=sort_func, reverse=sort_reverse)
        
        print(f"Directory: {RECORDINGS_DIR}")
        print(colored("─" * columns, "blue"))
        print(f"{colored('ID', 'cyan'):<4} | {colored('Filename', 'cyan'):<35} | {colored('Length', 'cyan'):<10} | {colored('Modified Date', 'cyan'):<20}")
        print(colored("─" * columns, "blue"))

        for i, f in enumerate(files, 1):
            path = os.path.join(RECORDINGS_DIR, f)
            try:
                mtime = time.strftime("%Y-%m-%d %H:%M", time.localtime(os.stat(path).st_mtime))
            except:
                mtime = "—"
            
            dur_str = format_duration(get_file_duration(path))
            display_name = f if len(f) <= 33 else f[:30] + "..."
            
            print(f"{colored(str(i), 'yellow'):<4} | {display_name:<35} | {dur_str:<10} | {mtime:<20}")

        print(colored("─" * columns, "blue"))
        print(colored("Actions:", "cyan"))
        print("  [ID] Manage file    [S] Change sort")
        print("  [O] Toggle order    [B] Back to main menu")

        choice = input("\nEnter choice: ").strip().lower()

        if choice == 'b':
            return
        elif choice == 's':
            sort_key = input("Sort by (date/name/duration): ").strip().lower()
            if sort_key not in ('date', 'name', 'duration'): sort_key = 'date'
        elif choice == 'o':
            sort_reverse = not sort_reverse
        else:
            try:
                num = int(choice)
                if 1 <= num <= len(files):
                    manage_file(files[num - 1])
            except ValueError:
                print(colored("[!] Invalid input", "red"))
                time.sleep(1)


def manage_file(filename):
    filepath = os.path.join(RECORDINGS_DIR, filename)
    while True:
        print_header("MANAGE FILE")
        print(f"Target: {colored(filename, 'yellow')}\n")
        
        print("  [1] Play Audio")
        print("  [2] Rename File")
        print("  [3] Move to Trash")
        print("  [B] Back to list")

        sub = input("\nSelect action: ").strip().lower()

        if sub == 'b':
            return
        elif sub == '1':
            play_recording(filepath)
        elif sub == '2':
            new_name = input("\nEnter new name (without .wav): ").strip()
            if new_name:
                new_name = "".join(c for c in new_name if c.isalnum() or c in " -_()[]") + ".wav"
                new_path = os.path.join(RECORDINGS_DIR, new_name)
                if not os.path.exists(new_path):
                    os.rename(filepath, new_path)
                    print(colored("[SUCCESS] File renamed.", "green"))
                    time.sleep(1)
                    return
                else:
                    print(colored("[ERROR] Name exists.", "red"))
                    time.sleep(1)
        elif sub == '3':
            dst = os.path.join(TRASH_DIR, filename)
            counter = 1
            base, ext = os.path.splitext(filename)
            while os.path.exists(dst):
                dst = os.path.join(TRASH_DIR, f"{base}_{counter}{ext}")
                counter += 1
            shutil.move(filepath, dst)
            print(colored("[SUCCESS] Moved to trash.", "green"))
            time.sleep(1)
            return


def trash_menu():
    while True:
        print_header("TRASH BIN")
        files = [f for f in os.listdir(TRASH_DIR) if f.lower().endswith(".wav")]

        if not files:
            print(colored("Trash is empty.", "yellow"))
            input("\nPress Enter to return...")
            return

        files = sorted(files, key=lambda f: os.path.getmtime(os.path.join(TRASH_DIR, f)), reverse=True)

        print(colored("─" * columns, "blue"))
        print(f"{colored('ID', 'cyan'):<4} | {colored('Filename', 'cyan'):<40} | {colored('Deleted Date', 'cyan'):<20}")
        print(colored("─" * columns, "blue"))

        for i, f in enumerate(files, 1):
            mtime = time.strftime("%Y-%m-%d %H:%M", time.localtime(os.path.getmtime(os.path.join(TRASH_DIR, f))))
            display_name = f if len(f) <= 38 else f[:35] + "..."
            print(f"{colored(str(i), 'yellow'):<4} | {display_name:<40} | {mtime:<20}")

        print(colored("─" * columns, "blue"))
        print(colored("Actions:", "cyan"))
        print("  [ID] Manage file    [E] Empty all trash")
        print("  [B] Back to menu")

        choice = input("\nEnter choice: ").strip().lower()

        if choice == 'b':
            return
        elif choice == 'e':
            confirm = input(colored("Type 'EMPTY' to permanently delete all items: ", "red")).strip()
            if confirm == 'EMPTY':
                for f in files: os.remove(os.path.join(TRASH_DIR, f))
                print(colored("\n[SUCCESS] Trash emptied.", "green"))
                time.sleep(1.5)
        else:
            try:
                num = int(choice)
                if 1 <= num <= len(files):
                    manage_trash_file(files[num - 1])
            except ValueError:
                pass


def manage_trash_file(filename):
    src = os.path.join(TRASH_DIR, filename)
    print_header("TRASH ACTION")
    print(f"Target: {filename}\n")
    print("  [1] Restore File")
    print("  [2] Permanently Delete")
    print("  [B] Cancel")

    sub = input("\nSelect action: ").strip().lower()

    if sub == '1':
        dst = os.path.join(RECORDINGS_DIR, filename)
        counter = 1
        base, ext = os.path.splitext(filename)
        while os.path.exists(dst):
            dst = os.path.join(RECORDINGS_DIR, f"{base}_restored_{counter}{ext}")
            counter += 1
        shutil.move(src, dst)
        print(colored("[SUCCESS] File restored.", "green"))
        time.sleep(1)
    elif sub == '2':
        os.remove(src)
        print(colored("[SUCCESS] File permanently deleted.", "green"))
        time.sleep(1)


def settings_menu():
    global CURRENT_QUALITY, RAW_SAVE_DIR, RECORDINGS_DIR, TRASH_DIR

    while True:
        print_header("CONFIGURATION")
        
        print(f"Configuration File: {colored(SETTINGS_FILE, 'cyan')}")
        print(f"Save Directory:     {colored(RAW_SAVE_DIR, 'cyan')}")
        print(f"Current Quality:    {colored(get_quality_name(), 'green')}\n")
        
        print(colored("Actions:", "cyan"))
        print("  [1] Change Quality")
        print("  [2] Change Storage Directory")
        print("  [B] Back to main menu")

        sel = input("\nSelect action: ").strip().lower()

        if sel == '1':
            print("\nAvailable Presets:")
            for key, data in QUALITY_PRESETS.items():
                marker = "-> " if key == CURRENT_QUALITY else "   "
                print(f"  {marker}{key.capitalize():<8} : {data['name']}")
            
            q_choice = input(colored("\nSelect quality (high/medium/low): ", "cyan")).strip().lower()
            if q_choice in QUALITY_PRESETS:
                CURRENT_QUALITY = q_choice
                save_settings()
                print(colored("[SUCCESS] Quality updated.", "green"))
                time.sleep(1)
        
        elif sel == '2':
            print(f"\nCurrent Directory: {RAW_SAVE_DIR}")
            new_dir = input("Enter new storage path (e.g., ~/Music/Audio): ").strip()
            if new_dir:
                RAW_SAVE_DIR = new_dir
                save_settings()
                
                # Update runtime variables immediately
                RECORDINGS_DIR = os.path.expanduser(RAW_SAVE_DIR)
                TRASH_DIR = os.path.join(RECORDINGS_DIR, ".trash")
                os.makedirs(RECORDINGS_DIR, exist_ok=True)
                os.makedirs(TRASH_DIR, exist_ok=True)
                
                print(colored("[SUCCESS] Storage path updated.", "green"))
                time.sleep(1.5)

        elif sel == 'b':
            return


